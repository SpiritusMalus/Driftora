{
  "name": "healthroutine-food-parse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Stateless food-parse service for HealthRoutine — Russian utterance → FoodParseResult via the Anthropic Messages API (tool use). The app's only external network call.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
