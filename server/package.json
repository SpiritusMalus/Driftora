{
  "name": "driftora-food-parse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Stateless food-parse service for Driftora — voice/text/photo → honest MealDraft. Gemini identifies foods + grams; exact per-100g nutrition comes from a region DB (USDA/Skurikhin/OFF), never the LLM.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "import:nutrition": "tsx scripts/srLegacyImport.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
