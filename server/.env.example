# === Food-parse service env (server-side only — NEVER ship keys to the app) ===

# OpenRouter API key (sk-or-v1-…) — vision + text identification. Required.
# OpenRouter is OpenAI-compatible and reachable from EEA hosts. Get one at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model slug (defaults to google/gemini-3.5-flash). Must be vision-capable for
# the photo route. Browse models at https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-3.5-flash
# Optional stronger model for low-confidence escalation (e.g. google/gemini-3.1-pro-preview).
# Leave unset to disable escalation.
OPENROUTER_PRO_MODEL=
# Optional base URL override (defaults to https://openrouter.ai/api/v1).
OPENROUTER_BASE_URL=

# USDA FoodData Central key — nutrition numbers (free). Required: US numbers
# AND the broad RU fallback (when the curated RU table misses, the item is
# re-queried by its English name). Get one at
# https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Optional paid text fallback (API Ninjas). Leave unset to disable.
APININJAS_KEY=

# Optional FatSecret Platform API (extra free-text fallback). NOTE: the free
# Basic tier is US-data + English-only; RU localization is paid Premier — so
# this does NOT close the RU gap (USDA-by-EN-name + OFF search do). OAuth2
# client-credentials key pair; both must be set to enable. Register an app at
# https://platform.fatsecret.com/
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Default nutrition region when the request omits one: US or RU (default US).
DEFAULT_REGION=US

# Port to listen on (default 8787).
PORT=8787

# Optional: static bearer token required on every request (Authorization:
# Bearer <token>). Leave unset to disable auth. Not tied to any user identity.
# The app supplies it from its EXPO_PUBLIC_FOOD_API_TOKEN build-time env var —
# only enable once installed builds carry the token, or they fall back offline.
APP_TOKEN=

# Optional: restrict CORS to a single origin. Leave unset to allow any origin.
ALLOWED_ORIGIN=

# === Per-IP rate limits (abuse / Gemini-quota guard) ===
# All optional; values are positive integers. Keying is per-IP behind Caddy
# (trust proxy = 1); IPv6 is grouped by /64. Defaults are generous on purpose —
# per-IP is coarse for mobile (CGNAT shares one IP across many users).
# Global burst guard: max requests per IP per minute, across all routes (default 30).
RL_BURST_PER_MIN=30
# Daily cap per IP on POST /food/parse (text) (default 300).
RL_TEXT_PER_DAY=300
# Daily cap per IP on POST /food/parse-photo (vision — pricier, tighter) (default 100).
RL_PHOTO_PER_DAY=100

# === Per-install daily AI quota (the CGNAT-safe metering layer) ===
# Requests per install per UTC day across ALL AI parse routes (food text/photo/
# audio + workout). Keyed by the client's random X-Install-Id header (no account,
# no device identifier); clients without the header share an ip-keyed fallback.
# The id is client-generated and spoofable — this meters honest apps and feeds
# the /metrics usage histogram (future free-tier / subscription sizing); the
# RL_* per-IP caps above remain the abuse backstop. 0 disables. Default 30.
AI_PER_INSTALL_PER_DAY=30

# Reasoning throttle for typed-TEXT LLM calls (identify text / workout text /
# label translate). The model's reasoning is mandatory upstream and can't be
# disabled, but its budget can: 'low' (default) answers ~3-5 s vs 13-27 s at
# full effort with the same parsed items (measured 2026-07-21 on the prod
# prompt). Vision and the estimator keep full effort. 'off' sends no reasoning
# field. Values: low | medium | high | off.
REASONING_EFFORT_TEXT=low

# Same throttle for the media paths (photo identify, package-label read, voice
# meal, workout photo/audio). Label misreads at low effort are caught by the
# cross-check (two independent parses must agree), so the failure mode is «no
# label», never wrong numbers. Values: low | medium | high | off.
REASONING_EFFORT_MEDIA=low
