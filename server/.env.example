# === Food-parse service env (server-side only — NEVER ship keys to the app) ===

# Gemini API key — vision + text identification (Gemini 3 Flash). Required.
GEMINI_API_KEY=
# Model id override (defaults to gemini-3-flash).
GEMINI_MODEL=gemini-3-flash
# Optional stronger model for low-confidence escalation (e.g. gemini-3-pro).
# Leave unset to disable escalation.
GEMINI_PRO_MODEL=

# USDA FoodData Central key — US nutrition numbers (free). Required for US.
# Get one at https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Optional paid text fallback (API Ninjas). Leave unset to disable.
APININJAS_KEY=

# Default nutrition region when the request omits one: US or RU (default US).
DEFAULT_REGION=US

# Port to listen on (default 8787).
PORT=8787

# Optional: static bearer token required on every request (Authorization:
# Bearer <token>). Leave unset to disable auth. Not tied to any user identity.
APP_TOKEN=

# Optional: restrict CORS to a single origin. Leave unset to allow any origin.
ALLOWED_ORIGIN=

# === Per-IP rate limits (abuse / Gemini-quota guard) ===
# All optional; values are positive integers. Keying is per-IP behind Caddy
# (trust proxy = 1); IPv6 is grouped by /64. Defaults are generous on purpose —
# per-IP is coarse for mobile (CGNAT shares one IP across many users).
# Global burst guard: max requests per IP per minute, across all routes (default 30).
RL_BURST_PER_MIN=30
# Daily cap per IP on POST /food/parse (text) (default 300).
RL_TEXT_PER_DAY=300
# Daily cap per IP on POST /food/parse-photo (vision — pricier, tighter) (default 100).
RL_PHOTO_PER_DAY=100
