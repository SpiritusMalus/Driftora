# Anthropic API key — server-side only, NEVER ship to the app/client bundle.
ANTHROPIC_API_KEY=sk-ant-...

# Port to listen on (default 8787).
PORT=8787

# Model used for the food parser. Defaults to claude-haiku-4-5 (fast + cheap,
# matching the intent documented in the app's stubFoodParser.ts). Switch to
# claude-opus-4-8 for higher accuracy — temperature is dropped automatically
# for the Opus 4.7+/Fable family, which reject it.
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: static bearer token required on every request (Authorization:
# Bearer <token>). Leave unset to disable auth. Not tied to any user identity.
APP_TOKEN=

# Optional: restrict CORS to a single origin. Leave unset to allow any origin.
ALLOWED_ORIGIN=
