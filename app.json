{
  "expo": {
    "name": "HealthRoutine",
    "slug": "health-routine",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "healthroutine",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Доступ к данным о шагах нужен, чтобы показывать вашу активность и её пользу для здоровья.",
        "NSSpeechRecognitionUsageDescription": "Распознавание речи используется для голосового ввода еды.",
        "NSMicrophoneUsageDescription": "Микрофон нужен для голосового ввода того, что вы съели."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.healthroutine.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      "expo-sqlite",
      "expo-notifications",
      "@react-native-voice/voice"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c10b5ed7-277d-46b0-97e6-79dde3fa07d3"
      }
    },
    "owner": "tihonenkoeugene"
  }
}
