# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# docs live in the Obsidian vault (itself outside git) — keep this repo code-only.
# No Markdown is tracked here. To keep a specific file, add an exception, e.g.
# `!README.md`, below this line.
*.md
# Exception: the repo README is the one tracked doc at the root (every git
# project should carry one).
!README.md
# Exception: the legal documents are product artifacts (rendered in-app and
# hosted at a public URL for the stores), so they ARE tracked here.
!legal/PRIVACY_POLICY.md
!legal/TERMS_OF_USE.md

.claude/
dist.stale.*

# IDE project files (JetBrains) — machine-local, never part of the app.
.idea/
*.iml

# Anchored to repo root: ignore the top-level nested mockup / handoff-ref dirs
# (duplicate UI, .dc.html, *-frame.jsx — never part of the RN build) WITHOUT
# matching nested package dirs like modules/.../com/driftora/ (macOS git is
# case-insensitive). The dir is named HealthRoutine/ on disk today; /Driftora/
# future-proofs the rebrand rename — keep both.
/Driftora/
/HealthRoutine/
