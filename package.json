    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^expo-localization$": "<rootDir>/__mocks__/expo-localization.ts",
      "^expo/virtual/env$": "<rootDir>/__mocks__/expo-virtual-env.ts",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.ts",
      "^expo-crypto$": "<rootDir>/__mocks__/expo-crypto.ts",
      "^expo-local-authentication$": "<rootDir>/__mocks__/expo-local-authentication.ts",
      "^expo-modules-core$": "<rootDir>/__mocks__/expo-modules-core.ts"
